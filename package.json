{
  "name": "japoweb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "App de estudio de japonés (kanji + vocabulario) — React + Vite + PWA",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "fetch:kvg": "node scripts/fetch-kanjivg.mjs",
    "fetch:kana": "node scripts/fetch-kana.mjs",
    "gen:icons": "node scripts/gen-icons.mjs",
    "gen:cap-assets": "node scripts/gen-cap-assets.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
